---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Gallery from '../components/Gallery';
import AnimatedCounter from '../components/AnimatedCounter';
import { services, WHATSAPP_URL, PHONE, ADDRESS } from '../data/services';
import { config } from '../data/clinic-config';

const doctorName = config.doctor?.name ?? 'nossa equipe';
const doctorCro = config.doctor?.cro ?? '';
const doctorDesc = config.doctor ? `${config.doctor.name} (${config.doctor.cro}). ` : '';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  name: config.name,
  description: `Clinica odontologica integrativa em ${config.neighborhood}, ${config.city}. ${doctorDesc}Ortodontia, implantes, lentes de resina, harmonizacao orofacial.`,
  url: config.siteUrl,
  telephone: `+${config.phone.replace(/\D/g, '')}`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: config.address.split(' - ')[0],
    addressLocality: config.city,
    addressRegion: config.state,
    postalCode: config.postalCode,
    addressCountry: 'BR',
  },
  priceRange: '$$',
  areaServed: { '@type': 'City', name: config.city },
  ...(config.doctor ? {
    founder: { '@type': 'Person', name: config.doctor.name, jobTitle: config.doctor.title, identifier: config.doctor.cro },
  } : {}),
};
---

<Layout
  title={`${config.name} — Dentista em ${config.neighborhood}, ${config.city}`}
  description={`Clinica odontologica integrativa em ${config.neighborhood}. ${doctorDesc}Ortodontia, implantes, lentes de resina, harmonizacao orofacial. Agende pelo WhatsApp.`}
  schema={schema}
  preloadImage="/images/hero.webp"
>

  <!-- ============ HERO ============ -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden bg-warm-50">
    <!-- Subtle gold gradient accent -->
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-gold-50/40 to-transparent pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-0 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-12 lg:gap-8 items-center">

        <!-- Text Content -->
        <div class="order-2 lg:order-1 max-w-xl">
          <div class="animate-on-scroll">
            <span class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.25em] text-gold-600 mb-6">
              <span class="w-8 h-[1px] bg-gold-400"></span>
              {config.neighborhood} — {config.city}
            </span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-[4rem] font-extrabold text-warm-900 leading-[1.05] tracking-tight animate-on-scroll">
            Seu sorriso merece
            <span class="block gold-text mt-1">cuidado de verdade</span>
          </h1>

          <p class="mt-7 text-lg text-warm-400 leading-relaxed animate-on-scroll">
            Odontologia integrativa com atendimento humanizado. Tratamos cada paciente como unico — porque cuidar de voce e a nossa missao.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-on-scroll">
            <a
              href={WHATSAPP_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 bg-warm-900 text-white font-semibold px-8 py-4 rounded-full hover:bg-warm-800 transition-all btn-press text-[15px] tracking-wide"
            >
              <svg class="w-5 h-5 text-green-400" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
              </svg>
              Agendar Consulta
            </a>
            <a
              href="/servicos"
              class="inline-flex items-center justify-center gap-2 border border-warm-200 text-warm-600 font-semibold px-8 py-4 rounded-full hover:border-gold-300 hover:text-gold-600 transition-all text-[15px]"
            >
              Nossos Servicos
            </a>
          </div>

          <!-- Trust line -->
          <div class="mt-10 flex items-center gap-4 animate-on-scroll">
            <div class="flex -space-x-2">
              <div class="w-8 h-8 bg-gold-100 rounded-full border-2 border-white flex items-center justify-center text-[10px] font-bold text-gold-600">M</div>
              <div class="w-8 h-8 bg-gold-100 rounded-full border-2 border-white flex items-center justify-center text-[10px] font-bold text-gold-600">C</div>
              <div class="w-8 h-8 bg-gold-100 rounded-full border-2 border-white flex items-center justify-center text-[10px] font-bold text-gold-600">A</div>
            </div>
            <div>
              <div class="flex gap-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-3.5 h-3.5 text-gold-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <p class="text-[11px] text-warm-400 mt-0.5">Pacientes satisfeitos</p>
            </div>
          </div>
        </div>

        <!-- Hero Image — 3D tilt container -->
        <div class="order-1 lg:order-2 animate-on-scroll slide-right lg:-mr-8" style="perspective: 1000px;">
          <div id="hero-tilt" class="relative transition-transform duration-200 ease-out" style="transform-style: preserve-3d;">
            <!-- Gold accent ring — parallax layer (deeper) -->
            <div class="absolute -inset-3 bg-gradient-to-br from-gold-200/30 via-transparent to-gold-100/20 rounded-[2rem] blur-sm" style="transform: translateZ(-20px);"></div>
            <div class="relative overflow-hidden rounded-[1.5rem] bg-white shadow-2xl shadow-warm-900/[0.06]" style="transform: translateZ(0);">
              <img
                src="/images/hero.webp"
                alt={`${config.name} — Dentista em ${config.neighborhood}`}
                class="w-full h-auto object-cover lg:min-h-[500px]"
                width="1920"
                height="720"
                loading="eager"
                fetchpriority="high"
              />
            </div>
            <!-- Floating badge — pops forward in 3D + float animation -->
            {config.doctor && (
              <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-lg shadow-warm-900/[0.08] p-4 border border-warm-100 animate-on-scroll scale-in hero-float" style="transform: translateZ(40px);">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-gold-50 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-bold text-warm-800">{config.doctor.name}</p>
                    <p class="text-[10px] text-warm-400">{config.doctor.cro}</p>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hero 3D tilt — desktop only, lightweight -->
  <script>
    if (window.matchMedia('(min-width: 1024px)').matches) {
      const card = document.getElementById('hero-tilt');
      if (card) {
        const parent = card.parentElement!;
        parent.addEventListener('mousemove', (e) => {
          const rect = parent.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          card.style.transform = `rotateY(${x * 8}deg) rotateX(${-y * 6}deg)`;
        });
        parent.addEventListener('mouseleave', () => {
          card.style.transform = 'rotateY(0deg) rotateX(0deg)';
        });
      }
    }
  </script>

  <!-- ============ TRUST BAR ============ -->
  <section class="py-10 border-y border-warm-100 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 items-center">
        <div class="text-center animate-on-scroll">
          <p class="text-[11px] uppercase tracking-[0.2em] text-warm-300 font-medium">Atendimento</p>
          <p class="text-sm font-bold text-warm-700 mt-1">Particular</p>
        </div>
        <div class="w-px h-8 bg-warm-100 hidden md:block"></div>
        <div class="text-center animate-on-scroll">
          <p class="text-[11px] uppercase tracking-[0.2em] text-warm-300 font-medium">Horario</p>
          <p class="text-sm font-bold text-warm-700 mt-1">Seg-Sab</p>
        </div>
        <div class="w-px h-8 bg-warm-100 hidden md:block"></div>
        <div class="text-center animate-on-scroll">
          <p class="text-[11px] uppercase tracking-[0.2em] text-warm-300 font-medium">Localizacao</p>
          <p class="text-sm font-bold text-warm-700 mt-1">{config.neighborhood}, {config.state}</p>
        </div>
        <div class="w-px h-8 bg-warm-100 hidden md:block"></div>
        <div class="text-center animate-on-scroll">
          <p class="text-[11px] uppercase tracking-[0.2em] text-warm-300 font-medium">Especialidades</p>
          <p class="text-sm font-bold text-warm-700 mt-1">{services.length}+</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="py-24 lg:py-32 relative">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <SectionHeading
        label="Nossos Servicos"
        title="Tratamentos que transformam sorrisos"
        subtitle="Da prevencao a estetica — cada tratamento e planejado com cuidado e executado com excelencia."
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger">
        {services.map((service) => (
          <ServiceCard
            icon={service.icon}
            title={service.shortTitle}
            description={service.tagline}
            href={`/servicos/${service.slug}`}
          />
        ))}
      </div>

      <div class="text-center mt-14 animate-on-scroll">
        <a href="/servicos" class="inline-flex items-center gap-2 text-gold-600 font-semibold hover:text-gold-700 transition-colors link-underline text-sm tracking-wide">
          Ver todos os servicos
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ ABOUT PREVIEW ============ -->
  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="animate-on-scroll slide-left">
          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-br from-gold-100/50 to-transparent rounded-3xl"></div>
            <div class="relative img-zoom rounded-2xl overflow-hidden">
              <img
                src="/images/gallery-1.webp"
                alt={`Clinica ${config.name}`}
                class="w-full aspect-[3/4] object-cover"
                width="600"
                height="800"
                loading="lazy"
              />
            </div>
          </div>
        </div>

        <div class="animate-on-scroll slide-right">
          <span class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.25em] text-gold-600 mb-4">
            <span class="w-8 h-[1px] bg-gold-400"></span>
            Sobre Nos
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-warm-900 leading-[1.1] mb-6">
            Odontologia integrativa:<br />cuidado que vai<br />
            <span class="gold-text">alem do sorriso</span>
          </h2>
          <p class="text-warm-400 leading-relaxed mb-5">
            Na {config.name}, acreditamos que saude bucal esta diretamente conectada ao bem-estar emocional e fisico. Cada atendimento e pensado de forma integrativa — considerando o paciente como um todo.
          </p>
          <p class="text-warm-400 leading-relaxed mb-8">
            {config.doctor
              ? `Com ${config.doctor.name} a frente, criamos um ambiente acolhedor onde voce se sente seguro para cuidar do que mais importa: o seu sorriso.`
              : `Criamos um ambiente acolhedor onde voce se sente seguro para cuidar do que mais importa: o seu sorriso.`
            }
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-6 mb-8">
            <AnimatedCounter client:visible value={services.length} suffix="+" label="Especialidades" />
            <AnimatedCounter client:visible value={config.rating} suffix="★" label="Avaliacao" />
            <AnimatedCounter client:visible value={100} suffix="%" label="Dedicacao" />
          </div>

          <a href="/sobre" class="inline-flex items-center gap-2 bg-warm-900 text-white font-semibold px-7 py-3.5 rounded-full hover:bg-warm-800 transition-all btn-press text-sm tracking-wide">
            Conheca Nossa Clinica
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ GALLERY ============ -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        label="Nossa Clinica"
        title="Um espaco pensado para voce"
        subtitle="Conheca o ambiente onde cuidado e sofisticacao se encontram."
      />

      <Gallery client:visible />
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="py-24 lg:py-32 bg-warm-50 relative">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <SectionHeading
        label="Depoimentos"
        title="O que nossos pacientes dizem"
        subtitle="Historias reais de quem confiou no nosso cuidado."
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 stagger">
        <TestimonialCard
          name="Mariana S."
          treatment="Lentes de Resina"
          quote="Sempre tive vergonha de sorrir. Depois das lentes de resina, minha autoestima mudou completamente. A equipe e maravilhosa e super cuidadosa."
        />
        <TestimonialCard
          name="Carlos R."
          treatment="Implante Dentario"
          quote="Perdi um dente ha anos e evitava sorrir. O implante ficou tao natural que ninguem percebe. Recomendo de olhos fechados."
        />
        <TestimonialCard
          name="Ana Paula L."
          treatment="Ortodontia"
          quote="Atendimento humanizado de verdade. Me senti acolhida desde a primeira consulta. Os resultados superaram minhas expectativas."
        />
      </div>

      <div class="text-center mt-14 animate-on-scroll">
        <a href="/depoimentos" class="inline-flex items-center gap-2 text-gold-600 font-semibold hover:text-gold-700 transition-colors link-underline text-sm tracking-wide">
          Ver mais depoimentos
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="relative py-24 lg:py-32 bg-warm-900 overflow-hidden">
    <!-- Subtle pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(196,154,60,0.8) 1px, transparent 0); background-size: 40px 40px;"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center z-10">
      <div class="animate-on-scroll">
        <span class="inline-block text-[11px] font-bold uppercase tracking-[0.25em] text-gold-400/60 mb-4">
          Agende Agora
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-[1.1] mb-6">
          Pronto para transformar<br />
          <span class="bg-gradient-to-r from-gold-300 to-gold-500 bg-clip-text text-transparent">o seu sorriso?</span>
        </h2>
        <p class="text-lg text-white/50 mb-10 max-w-xl mx-auto">
          {config.doctor
            ? `Agende uma avaliacao sem compromisso com ${config.doctor.name}. Vamos criar juntos o plano ideal para voce.`
            : `Agende uma avaliacao sem compromisso. Vamos criar juntos o plano ideal para voce.`
          }
        </p>
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-white text-warm-900 font-bold px-10 py-4 rounded-full hover:bg-gold-50 hover:shadow-lg hover:shadow-gold-500/10 transition-all btn-press text-[15px] tracking-wide"
        >
          <svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
          </svg>
          Agendar Minha Consulta
        </a>
        <p class="mt-5 text-[13px] text-white/25">Resposta em ate 30 min - Sem compromisso</p>
      </div>
    </div>
  </section>

  <!-- ============ LOCATION ============ -->
  <section class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        label="Localizacao"
        title="Facil de chegar"
        subtitle={`No coracao de ${config.neighborhood}, com facil acesso por transporte publico.`}
      />

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <div class="animate-on-scroll slide-left">
          <div class="luxury-card p-8 space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 bg-gold-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-warm-800 mb-1">Endereco</h3>
                <p class="text-sm text-warm-400">{ADDRESS}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-11 h-11 bg-gold-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-warm-800 mb-1">Horario</h3>
                <p class="text-sm text-warm-400">Segunda a Sexta: {config.hours.weekdays}</p>
                <p class="text-sm text-warm-400">Sabado: {config.hours.saturday}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-11 h-11 bg-green-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-warm-800 mb-1">WhatsApp</h3>
                <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="text-sm text-gold-600 hover:text-gold-700 font-semibold">
                  {PHONE}
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="animate-on-scroll slide-right">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden border border-warm-100">
            {config.mapsEmbed ? (
              <iframe
                src={config.mapsEmbed}
                width="100%"
                height="100%"
                style="border:0"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Localizacao ${config.name}`}
              ></iframe>
            ) : (
              <div class="w-full h-full bg-warm-50 flex items-center justify-center">
                <div class="text-center p-8">
                  <svg class="w-12 h-12 text-warm-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <p class="text-warm-400 text-sm">{ADDRESS}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
