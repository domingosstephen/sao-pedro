---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { WHATSAPP_URL } from '../data/services';
import { config } from '../data/clinic-config';

const doctorDesc = config.doctor ? ` da ${config.doctor.name} (${config.doctor.cro})` : '';
---

<Layout
  title="Sobre a Clinica"
  description={`Conheca ${config.name} em ${config.neighborhood}: odontologia integrativa com atendimento humanizado${doctorDesc}.`}
>

  <section class="bg-warm-900 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/' },
        { label: 'Sobre a Clinica' },
      ]} />
      <div class="max-w-3xl animate-on-scroll">
        <span class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.25em] text-gold-400/60 mb-4">
          <span class="w-8 h-[1px] bg-gold-500/40"></span>
          Nossa Historia
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
          Cuidado que vai alem<br />
          <span class="bg-gradient-to-r from-gold-300 to-gold-500 bg-clip-text text-transparent">do consultorio</span>
        </h1>
        <p class="mt-6 text-lg text-white/50 leading-relaxed">
          Nascemos da conviccao de que odontologia e mais do que tratar dentes — e cuidar de pessoas.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="animate-on-scroll slide-left">
          <div class="relative">
            <div class="absolute -inset-3 bg-gradient-to-br from-gold-100/40 to-transparent rounded-3xl"></div>
            <div class="relative img-zoom rounded-2xl overflow-hidden">
              <img src="/images/gallery-3.webp" alt={`Interior da ${config.name}`} class="w-full aspect-[3/4] object-cover" loading="lazy" />
            </div>
          </div>
        </div>
        <div class="animate-on-scroll slide-right">
          <span class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.25em] text-gold-600 mb-4">
            <span class="w-8 h-[1px] bg-gold-400"></span>
            Nossa Missao
          </span>
          <h2 class="text-3xl font-bold text-warm-900 leading-[1.1] mb-6">
            Odontologia integrativa: saude, estetica e <span class="gold-text">bem-estar</span>
          </h2>
          <p class="text-warm-400 leading-relaxed mb-4">
            A {config.name} nasceu com uma missao clara: <strong class="text-warm-700">oferecer atendimento odontologico humanizado</strong> que considera o paciente como um todo.
          </p>
          <p class="text-warm-400 leading-relaxed mb-4">
            Localizada no coracao de {config.neighborhood}, {config.region}, nossa clinica foi pensada para ser um espaco acolhedor onde cada paciente se sente seguro e respeitado.
          </p>
          <p class="text-warm-400 leading-relaxed">
            {config.doctor
              ? `Sob a lideranca de ${config.doctor.name}, acreditamos que um sorriso bonito comeca com saude — e saude comeca com cuidado de verdade.`
              : `Acreditamos que um sorriso bonito comeca com saude — e saude comeca com cuidado de verdade.`
            }
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 lg:py-28 bg-warm-50 relative">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <SectionHeading label="Nossos Valores" title="O que nos guia todos os dias" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 stagger">
        <div class="luxury-card p-7 animate-on-scroll">
          <div class="w-12 h-12 bg-gold-50 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h3 class="font-bold text-warm-800 mb-2">Humanizacao</h3>
          <p class="text-sm text-warm-400 leading-relaxed">Cada paciente e unico. Ouvimos, acolhemos e respeitamos a individualidade de cada um.</p>
        </div>
        <div class="luxury-card p-7 animate-on-scroll">
          <div class="w-12 h-12 bg-gold-50 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <h3 class="font-bold text-warm-800 mb-2">Excelencia</h3>
          <p class="text-sm text-warm-400 leading-relaxed">Investimos em atualizacao constante e tecnologia de ponta para os melhores resultados.</p>
        </div>
        <div class="luxury-card p-7 animate-on-scroll">
          <div class="w-12 h-12 bg-gold-50 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M10.05 4.575a1.575 1.575 0 10-3.15 0v3m3.15-3v-1.5a1.575 1.575 0 013.15 0v1.5m-3.15 0l.075 5.925m3.075.75V4.575m0 0a1.575 1.575 0 013.15 0V15M6.9 7.575a1.575 1.575 0 10-3.15 0v8.175a6.75 6.75 0 006.75 6.75h2.018a5.25 5.25 0 003.712-1.538l1.732-1.732a5.25 5.25 0 001.538-3.712l.003-2.024a.668.668 0 00-.659-.677c-.757-.012-1.87.39-2.206 1.498" />
            </svg>
          </div>
          <h3 class="font-bold text-warm-800 mb-2">Transparencia</h3>
          <p class="text-sm text-warm-400 leading-relaxed">Explicamos cada etapa do tratamento. Sem surpresas, sem letra miuda.</p>
        </div>
        <div class="luxury-card p-7 animate-on-scroll">
          <div class="w-12 h-12 bg-gold-50 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-warm-800 mb-2">Integralidade</h3>
          <p class="text-sm text-warm-400 leading-relaxed">Olhamos para a saude bucal como parte do bem-estar completo — corpo, mente e sorriso.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Clinic Images -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="img-zoom rounded-2xl overflow-hidden animate-on-scroll"><img src="/images/gallery-2.webp" alt="Consultorio" class="w-full aspect-square object-cover" loading="lazy" /></div>
        <div class="img-zoom rounded-2xl overflow-hidden animate-on-scroll"><img src="/images/gallery-3.webp" alt="Recepcao" class="w-full aspect-square object-cover" loading="lazy" /></div>
        <div class="img-zoom rounded-2xl overflow-hidden animate-on-scroll"><img src="/images/gallery-4.webp" alt="Equipamentos" class="w-full aspect-square object-cover" loading="lazy" /></div>
        <div class="img-zoom rounded-2xl overflow-hidden animate-on-scroll"><img src="/images/gallery-5.webp" alt="Fachada" class="w-full aspect-square object-cover" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-warm-900">
    <div class="max-w-3xl mx-auto px-4 text-center animate-on-scroll">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Conheca nossa clinica pessoalmente</h2>
      <p class="text-white/40 mb-8">Agende uma visita e veja como cuidamos de cada detalhe para o seu conforto.</p>
      <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white text-warm-900 font-bold px-8 py-4 rounded-full hover:bg-gold-50 transition-all btn-press">
        Agendar Visita
      </a>
    </div>
  </section>
</Layout>
