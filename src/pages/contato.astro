---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { WHATSAPP_URL, PHONE, ADDRESS, GOOGLE_MAPS_EMBED, INSTAGRAM } from '../data/services';
import { config } from '../data/clinic-config';
---

<Layout title="Contato e Localizacao" description={`Entre em contato com ${config.name} em ${config.neighborhood}. Agende pelo WhatsApp ${config.phone}. ${config.address}.`}>

  <section class="bg-warm-900 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Contato' }]} />
      <div class="max-w-3xl animate-on-scroll">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
          Fale <span class="bg-gradient-to-r from-gold-300 to-gold-500 bg-clip-text text-transparent">conosco</span>
        </h1>
        <p class="mt-6 text-lg text-white/50 leading-relaxed">Estamos prontos para atender voce.</p>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="space-y-5">
          <!-- WhatsApp -->
          <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="group block luxury-card p-6 hover:border-green-200 animate-on-scroll">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center shrink-0">
                <svg class="w-7 h-7 text-green-500" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-warm-800 group-hover:text-green-600 transition-colors">WhatsApp</h3>
                <p class="text-green-600 font-semibold">{PHONE}</p>
                <p class="text-xs text-warm-400 mt-1">Resposta em ate 30 minutos</p>
              </div>
            </div>
          </a>

          <!-- Address -->
          <div class="luxury-card p-6 animate-on-scroll">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-gold-50 rounded-2xl flex items-center justify-center shrink-0">
                <svg class="w-7 h-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-warm-800">Endereco</h3>
                <p class="text-warm-500">{ADDRESS}</p>
                <p class="text-xs text-warm-400 mt-1">{config.neighborhood} — {config.region}</p>
              </div>
            </div>
          </div>

          <!-- Hours -->
          <div class="luxury-card p-6 animate-on-scroll">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 bg-gold-50 rounded-2xl flex items-center justify-center shrink-0">
                <svg class="w-7 h-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-warm-800">Horario</h3>
                <div class="mt-2 space-y-1">
                  <div class="flex justify-between text-sm max-w-xs"><span class="text-warm-400">Segunda a Sexta</span><span class="text-warm-600 font-medium">{config.hours.weekdays}</span></div>
                  <div class="flex justify-between text-sm max-w-xs"><span class="text-warm-400">Sabado</span><span class="text-warm-600 font-medium">{config.hours.saturday}</span></div>
                  <div class="flex justify-between text-sm max-w-xs"><span class="text-warm-400">Domingo</span><span class="text-warm-300">{config.hours.sunday}</span></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Instagram (conditional) -->
          {config.instagram && (
            <a href={config.instagram} target="_blank" rel="noopener noreferrer" class="group block luxury-card p-6 hover:border-purple-200 animate-on-scroll">
              <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl flex items-center justify-center shrink-0">
                  <svg class="w-7 h-7 text-purple-500" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-warm-800 group-hover:text-purple-600 transition-colors">Instagram</h3>
                  <p class="text-purple-500 font-medium text-sm">{config.instagram.replace('https://www.instagram.com/', '@').replace('/', '')}</p>
                </div>
              </div>
            </a>
          )}
        </div>

        <div class="animate-on-scroll slide-right">
          <div class="aspect-square lg:aspect-auto lg:h-full min-h-[400px] rounded-2xl overflow-hidden border border-warm-200">
            {config.mapsEmbed ? (
              <iframe src={GOOGLE_MAPS_EMBED} width="100%" height="100%" style="border:0; min-height:400px;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title={`Localizacao ${config.name}`}></iframe>
            ) : (
              <div class="w-full h-full min-h-[400px] bg-warm-50 flex items-center justify-center">
                <div class="text-center p-8">
                  <svg class="w-16 h-16 text-warm-200 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  <p class="text-warm-500 font-medium">{config.neighborhood} — {config.city}</p>
                  <p class="text-warm-400 text-sm mt-1">{ADDRESS}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
