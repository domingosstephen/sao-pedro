---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const schemaItems = items.map((item, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: item.label,
  ...(item.href && { item: new URL(item.href, Astro.site || 'https://idealcentroodontologico.com.br').href }),
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
};
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol class="flex items-center gap-1.5 text-sm text-white/30">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && (
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class="hover:text-gold-300 transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-white/60 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
