---
interface Props {
  name: string;
  treatment: string;
  quote: string;
  stars?: number;
}

const { name, treatment, quote, stars = 5 } = Astro.props;
---

<div class="luxury-card p-7 lg:p-8 animate-on-scroll relative overflow-hidden">
  <!-- Decorative quote mark -->
  <div class="absolute top-4 right-5 text-6xl font-serif text-gold-100 leading-none select-none pointer-events-none">"</div>

  <!-- Stars -->
  <div class="flex gap-0.5 mb-5">
    {Array.from({ length: stars }).map(() => (
      <svg class="w-4 h-4 text-gold-400" viewBox="0 0 20 20" fill="currentColor">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <blockquote class="text-warm-600 leading-relaxed mb-6 relative z-10 italic">
    &ldquo;{quote}&rdquo;
  </blockquote>

  <div class="flex items-center gap-3 relative z-10">
    <div class="w-10 h-10 bg-gradient-to-br from-gold-100 to-gold-200 rounded-full flex items-center justify-center text-gold-700 font-bold text-sm">
      {name.charAt(0)}
    </div>
    <div>
      <p class="text-sm font-bold text-warm-800">{name}</p>
      <p class="text-xs text-warm-400">{treatment}</p>
    </div>
  </div>
</div>
