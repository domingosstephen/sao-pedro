---
import { services, WHATSAPP_URL, PHONE, ADDRESS, INSTAGRAM } from '../data/services';
import { config } from '../data/clinic-config';
---

<footer class="bg-warm-900 text-white relative overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center">
            <span class="text-sm font-extrabold text-gold-400">{config.shortName.charAt(0)}</span>
          </div>
          <div>
            <span class="text-sm font-bold tracking-wider block leading-none">{config.shortName}</span>
            <span class="text-[10px] text-white/40 tracking-[0.2em] uppercase">{config.subtitle}</span>
          </div>
        </div>
        <p class="text-sm text-white/40 leading-relaxed max-w-xs">
          Odontologia integrativa com atendimento humanizado. Cuidamos do seu sorriso e do seu bem-estar.
        </p>
        {config.doctor && (
          <p class="text-sm text-white/40 mt-3">
            {config.doctor.name} — {config.doctor.cro}
          </p>
        )}
      </div>

      <!-- Servicos -->
      <div>
        <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-gold-400/60 mb-5">Servicos</h3>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a href={`/servicos/${s.slug}`} class="text-sm text-white/50 hover:text-gold-300 transition-colors duration-300">
                {s.shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- A Clinica -->
      <div>
        <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-gold-400/60 mb-5">A Clinica</h3>
        <ul class="space-y-3">
          <li><a href="/sobre" class="text-sm text-white/50 hover:text-gold-300 transition-colors duration-300">Sobre Nos</a></li>
          <li><a href="/sobre/equipe" class="text-sm text-white/50 hover:text-gold-300 transition-colors duration-300">Nossa Equipe</a></li>
          <li><a href="/depoimentos" class="text-sm text-white/50 hover:text-gold-300 transition-colors duration-300">Depoimentos</a></li>
          <li><a href="/blog" class="text-sm text-white/50 hover:text-gold-300 transition-colors duration-300">Blog</a></li>
          <li><a href="/contato" class="text-sm text-white/50 hover:text-gold-300 transition-colors duration-300">Contato</a></li>
        </ul>
      </div>

      <!-- Contato -->
      <div>
        <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-gold-400/60 mb-5">Contato</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <div class="w-8 h-8 bg-white/5 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-gold-400/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <span class="text-sm text-white/50">{ADDRESS}</span>
          </li>
          <li>
            <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-white/50 hover:text-green-300 transition-colors duration-300">
              <div class="w-8 h-8 bg-green-500/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-green-400" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
                </svg>
              </div>
              {PHONE}
            </a>
          </li>
        </ul>

        <div class="mt-6 pt-5 border-t border-white/[0.06]">
          <p class="text-[11px] uppercase tracking-[0.15em] text-white/30 mb-2">Horario</p>
          <p class="text-sm text-white/50">Seg-Sex: {config.hours.weekdays}</p>
          <p class="text-sm text-white/50">Sab: {config.hours.saturday}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom -->
  <div class="border-t border-white/[0.06]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/25">
        &copy; {new Date().getFullYear()} {config.name}. Todos os direitos reservados.
      </p>
      <div class="flex gap-6">
        <a href="/privacidade" class="text-xs text-white/25 hover:text-white/50 transition-colors">Privacidade</a>
        <a href="/termos" class="text-xs text-white/25 hover:text-white/50 transition-colors">Termos</a>
      </div>
    </div>
  </div>
</footer>
