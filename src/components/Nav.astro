---
import { services } from '../data/services';
import { WHATSAPP_URL } from '../data/services';
import { config } from '../data/clinic-config';

const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Início', href: '/' },
  {
    label: 'Serviços',
    href: '/servicos',
    children: services.map((s) => ({
      label: s.shortTitle,
      href: `/servicos/${s.slug}`,
    })),
  },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Depoimentos', href: '/depoimentos' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contato', href: '/contato' },
];
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-18 lg:h-22">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 bg-gold-50 rounded-full border border-gold-200 group-hover:border-gold-400 transition-colors flex items-center justify-center">
          <span class="text-sm font-extrabold text-gold-600">{config.shortName.charAt(0)}</span>
        </div>
        <div class="hidden sm:block">
          <span class="text-sm font-bold text-warm-800 tracking-wide block leading-none">{config.shortName}</span>
          <span class="text-[10px] text-warm-400 tracking-[0.2em] uppercase">{config.subtitle}</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-0.5">
        {navLinks.map((link) => (
          <div class="relative group">
            <a
              href={link.href}
              class:list={[
                'px-4 py-2 text-[13px] font-medium tracking-wide transition-colors relative',
                currentPath === link.href || currentPath.startsWith(link.href + '/')
                  ? 'text-gold-600'
                  : 'text-warm-500 hover:text-warm-800',
              ]}
            >
              {link.label}
              {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href + '/'))) && (
                <span class="absolute bottom-0 left-4 right-4 h-[2px] bg-gradient-to-r from-gold-400 to-gold-300 rounded-full"></span>
              )}
              {link.children && (
                <svg class="inline-block w-3 h-3 ml-1 -mt-0.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {link.children && (
              <div class="absolute top-full left-0 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 -translate-y-2 group-hover:translate-y-0">
                <div class="bg-white/95 backdrop-blur-xl rounded-2xl shadow-xl shadow-warm-900/[0.06] border border-warm-100 py-3 min-w-[240px]">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-5 py-2.5 text-[13px] text-warm-500 hover:text-gold-600 hover:bg-gold-50 transition-all font-medium"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- CTA + Mobile -->
      <div class="flex items-center gap-3">
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-2 bg-warm-800 text-white text-[13px] font-semibold px-6 py-2.5 rounded-full hover:bg-warm-900 transition-all btn-press tracking-wide"
        >
          <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
          Agendar Consulta
        </a>

        <button
          id="mobile-toggle"
          class="lg:hidden p-2 -mr-2 text-warm-600"
          aria-label="Abrir menu"
        >
          <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white/98 backdrop-blur-xl border-t border-warm-100">
    <div class="px-5 py-6 space-y-1 max-w-lg mx-auto">
      {navLinks.map((link) => (
        <>
          <a
            href={link.href}
            class="block px-4 py-3 text-sm font-medium text-warm-700 hover:text-gold-600 hover:bg-gold-50 rounded-xl transition-all"
          >
            {link.label}
          </a>
          {link.children && link.children.map((child) => (
            <a
              href={child.href}
              class="block pl-8 pr-4 py-2.5 text-sm text-warm-400 hover:text-gold-600 transition-all"
            >
              {child.label}
            </a>
          ))}
        </>
      ))}
      <div class="pt-4">
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-center bg-warm-800 text-white text-sm font-semibold px-6 py-3.5 rounded-full"
        >
          Agendar Consulta
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-18 lg:h-22"></div>

<script>
  const nav = document.getElementById('nav')!;
  const onScroll = () => {
    if (window.scrollY > 30) {
      nav.classList.add('glass', 'shadow-sm');
      nav.style.borderBottom = '1px solid rgba(236,232,225,0.6)';
    } else {
      nav.classList.remove('glass', 'shadow-sm');
      nav.style.borderBottom = 'none';
      nav.style.background = '';
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const toggle = document.getElementById('mobile-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const hamburger = document.getElementById('hamburger-icon')!;
  const closeIcon = document.getElementById('close-icon')!;
  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    hamburger.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
  });
</script>
