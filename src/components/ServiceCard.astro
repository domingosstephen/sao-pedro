---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
}

const { icon, title, description, href } = Astro.props;
---

<a href={href} class="group block animate-on-scroll">
  <div class="luxury-card p-7 lg:p-8 h-full cursor-glow">
    <div class="w-14 h-14 bg-gold-50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-gold-100 transition-all duration-500 group-hover:scale-105">
      <svg class="w-7 h-7 text-gold-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    </div>
    <h3 class="text-lg font-bold text-warm-800 mb-2 group-hover:text-gold-600 transition-colors duration-300">
      {title}
    </h3>
    <p class="text-sm text-warm-400 leading-relaxed mb-5">
      {description}
    </p>
    <span class="inline-flex items-center text-[13px] font-semibold text-gold-600 gap-1.5 group-hover:gap-3 transition-all duration-300">
      Saiba mais
      <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
