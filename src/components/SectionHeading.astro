---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}

const { label, title, subtitle, centered = true, light = false } = Astro.props;
---

<div class:list={['animate-on-scroll', centered && 'text-center', 'mb-14 lg:mb-20']}>
  {label && (
    <span class:list={[
      'inline-block text-[11px] font-bold uppercase tracking-[0.25em] mb-4',
      light ? 'text-gold-300' : 'text-gold-500'
    ]}>
      {label}
    </span>
  )}
  <h2 class:list={[
    'text-3xl sm:text-4xl lg:text-[3.25rem] font-bold tracking-tight leading-[1.1]',
    light ? 'text-white' : 'text-warm-900'
  ]}>
    {title}
  </h2>
  {subtitle && (
    <p class:list={[
      'mt-5 text-lg max-w-2xl leading-relaxed',
      centered && 'mx-auto',
      light ? 'text-white/60' : 'text-warm-400'
    ]}>
      {subtitle}
    </p>
  )}
  <div class:list={['section-line mt-6', centered && 'mx-auto']}></div>
</div>
